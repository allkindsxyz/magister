---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const allCards = await getCollection('cards');
const deckCards = [
  ...allCards.filter(c => c.data.featured),
  ...allCards.filter(c => !c.data.featured),
].slice(0, 6);
const nBack = Math.max(0, deckCards.length - 1);
---

<section class="hero hatch" id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow2"></div>

  <div class="hero-left">
    <div class="hero-number" aria-hidden="true">54</div>
    <p class="hero-eyebrow">{t('hero.eyebrow')}</p>
    <h1 class="hero-title">
      {t('hero.title')}
      <span class="hero-title-sub">{t('hero.subtitle')}</span>
    </h1>
    <p class="hero-body">{t('hero.body')}</p>
    <div class="hero-cta">
      <a href="#acquire" class="btn btn-gold">{t('hero.cta_primary')}</a>
      <a href="#gallery" class="btn btn-outline">{t('hero.cta_secondary')}</a>
    </div>
  </div>

  <div class="hero-right">
    <div class="hero-deck" id="hero-deck">
      <div class="deck-stack" id="deck-stack" aria-hidden="true">
        {Array.from({ length: nBack }).map((_, i) => {
          const card = deckCards[i + 1];
          return (
            <div
              class="deck-card deck-card--back"
              data-depth={i + 1}
              style={`
                --stack-offset: ${(i + 1) * 10}px;
                --stack-rotate: ${(i + 1) * -3 + 2}deg;
                --stack-z: ${nBack - i};
              `}
            >
              {card && (
                <img src={card.data.image} alt="" loading="eager" decoding="async" />
              )}
            </div>
          );
        })}
      </div>

      <div
        class="deck-card deck-card--front"
        id="deck-front"
        role={deckCards.length > 1 ? 'button' : undefined}
        tabindex={deckCards.length > 1 ? 0 : -1}
        aria-label={deckCards.length > 1 ? t('hero.deck_next') : undefined}
        data-interactive={deckCards.length > 1 ? 'true' : 'false'}
      >
        <img
          id="deck-front-img"
          src={deckCards[0]?.data.image}
          alt={deckCards[0]?.data.title[lang]}
          loading="eager"
          decoding="async"
          draggable="false"
        />
      </div>

      <div class="hero-card-shadow"></div>
    </div>

    <p class="deck-caption" id="deck-caption">{deckCards[0]?.data.title[lang]}</p>
  </div>

  <div class="scroll-hint">
    <span>{t('scroll_hint')}</span>
    <div class="scroll-line"></div>
  </div>
</section>

<script
  id="hero-card-data"
  type="application/json"
  set:html={JSON.stringify(
    deckCards.map(c => ({
      image: c.data.image,
      title: c.data.title[lang],
    }))
  )}
></script>

<style>
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: start;
  position: relative;
  overflow-x: hidden;
  overflow-y: visible;
  padding-top: 5rem;
}

.hero-glow {
  position: absolute;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200,151,58,.07) 0%, transparent 70%);
  right: -50px;
  top: 42%;
  transform: translateY(-50%);
  pointer-events: none;
}

.hero-glow2 {
  position: absolute;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(122,30,0,.1) 0%, transparent 70%);
  left: 0;
  top: 12%;
  pointer-events: none;
}

/* Left column — raised so eyebrow aligns with top of card */
.hero-left {
  padding: 5.25rem 4rem 6rem 6rem;
  position: relative;
  z-index: 2;
}

.hero-number {
  font-family: 'Cinzel Decorative', serif;
  font-size: 11rem;
  font-weight: 700;
  color: rgba(200,151,58,.05);
  position: absolute;
  top: 2.5rem;
  left: 2rem;
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

.hero-eyebrow {
  font-family: 'Cinzel', serif;
  font-size: .62rem;
  letter-spacing: .55em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.75rem;
  opacity: 0;
  animation: fadeLeft 1s ease .2s forwards;
}

.hero-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(3.5rem, 6vw, 6.5rem);
  font-weight: 700;
  line-height: .95;
  color: var(--parch);
  text-shadow: 0 2px 40px rgba(200,151,58,.12);
  margin-bottom: 2rem;
  opacity: 0;
  animation: fadeLeft 1.1s ease .35s forwards;
  max-width: 100%;
}

.hero-title-sub {
  display: block;
  font-size: clamp(1.6rem, 3vw, 2.8rem);
  color: var(--gold);
  letter-spacing: .35em;
  margin-top: .5rem;
}

.hero-body {
  font-size: 1rem;
  color: var(--warm);
  font-style: italic;
  max-width: 400px;
  margin-bottom: 3rem;
  opacity: 0;
  animation: fadeLeft 1.1s ease .5s forwards;
  line-height: 1.75;
}

.hero-cta {
  display: flex;
  gap: 1.2rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeLeft 1s ease .65s forwards;
}

/* Right column — top aligned with eyebrow / card top */
.hero-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 5.1rem 5rem 5rem 2rem;
  position: relative;
  z-index: 3;
  opacity: 0;
  animation: fadeLeft 1.3s ease .5s forwards;
}

.hero-deck {
  position: relative;
  width: clamp(240px, 28vw, 360px);
  overflow: visible;
}

.hero-card-shadow {
  position: absolute;
  width: 80%;
  height: 24px;
  background: rgba(0,0,0,.5);
  bottom: -28px;
  left: 10%;
  filter: blur(20px);
  border-radius: 50%;
  pointer-events: none;
}

/* Stack: fixed geometry, only img src changes — no opacity flicker */
.deck-card--back {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  border-radius: 8px;
  overflow: hidden;
  transform: translateX(var(--stack-offset)) rotate(var(--stack-rotate));
  z-index: var(--stack-z);
  box-shadow:
    0 20px 60px rgba(0,0,0,.6),
    0 0 0 1px rgba(200,151,58,.18);
  pointer-events: none;
  backface-visibility: hidden;
  transform-style: preserve-3d;
}

.deck-card--back:nth-child(1) { filter: brightness(0.94); }
.deck-card--back:nth-child(2) { filter: brightness(0.88); }
.deck-card--back:nth-child(3) { filter: brightness(0.82); }
.deck-card--back:nth-child(4) { filter: brightness(0.76); }
.deck-card--back:nth-child(5) { filter: brightness(0.70); }

.deck-card--back img {
  width: 100%;
  display: block;
  filter: sepia(10%) contrast(1.04);
}

/*
 * Front card: no infinite float (it fought transitions/hover and caused glitches).
 * Exit / enter = dedicated @keyframes + animationend (with timeout fallback).
 */
.deck-card--front {
  position: relative;
  z-index: 10;
  /* Стабильная геометрия — без подпрыгивания при смене decode/img */
  aspect-ratio: 93 / 133;
  border-radius: 8px;
  overflow: hidden;
  box-shadow:
    0 40px 100px rgba(0,0,0,.8),
    0 0 0 1px rgba(200,151,58,.4),
    inset 0 0 0 1px rgba(255,255,255,.05);
  transform: rotate(-1deg);
  opacity: 1;
  outline: none;
  backface-visibility: hidden;
}

.deck-card--front[data-interactive='true'] {
  cursor: pointer;
}

.deck-card--front[data-interactive='true']:focus-visible {
  box-shadow:
    0 40px 100px rgba(0,0,0,.8),
    0 0 0 2px rgba(200,151,58,.55),
    inset 0 0 0 1px rgba(255,255,255,.05);
}

/* Idle hover: shadow only — never touch transform (avoids fighting keyframes) */
.deck-card--front:not(.is-busy)[data-interactive='true']:hover {
  box-shadow:
    0 48px 110px rgba(0,0,0,.82),
    0 0 0 1px rgba(200,151,58,.55),
    inset 0 0 0 1px rgba(255,255,255,.06);
}

.deck-card--front.is-busy {
  pointer-events: none;
  cursor: default;
}

/* Next: current card slides down off the deck */
.deck-card--front.anim-exit-next {
  animation: heroExitNext 0.44s cubic-bezier(0.45, 0, 0.55, 1) forwards;
}

/* Prev: current card slides up off the deck */
.deck-card--front.anim-exit-prev {
  animation: heroExitPrev 0.44s cubic-bezier(0.45, 0, 0.55, 1) forwards;
}

/* Пока меняем src: невидимо, без лишней анимации появления (она давала «дёрганье») */
.deck-card--front.swap-phase {
  animation: none !important;
  opacity: 0 !important;
  transform: rotate(-1deg) translateY(0) scale(1) !important;
}

.deck-card--front img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: contain;
  object-position: center top;
  filter: contrast(1.06) sepia(8%);
}

@keyframes heroExitNext {
  from {
    transform: rotate(-1deg) translateY(0) scale(1);
    opacity: 1;
  }
  to {
    transform: rotate(-2deg) translateY(112%) scale(0.93);
    opacity: 0;
  }
}

@keyframes heroExitPrev {
  from {
    transform: rotate(-1deg) translateY(0) scale(1);
    opacity: 1;
  }
  to {
    transform: rotate(2deg) translateY(-112%) scale(0.93);
    opacity: 0;
  }
}

.deck-caption {
  font-family: 'Cinzel', serif;
  font-size: .6rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--dimmer);
  margin-top: 1.35rem;
  text-align: center;
  min-height: 1.2em;
  transition: opacity .25s ease;
}

.scroll-hint {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  font-family: 'Cinzel', serif;
  font-size: .55rem;
  letter-spacing: .4em;
  text-transform: uppercase;
  color: var(--dimmer);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .7rem;
  opacity: 0;
  animation: fadeLeft 1s ease 1.6s forwards;
  pointer-events: none;
}

.scroll-line {
  width: 1px;
  height: 45px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

@media (max-width: 960px) {
  .hero {
    grid-template-columns: 1fr;
    min-height: auto;
    padding-top: 5rem;
  }

  .hero-right {
    padding: 3rem 2rem 1rem;
    order: -1;
  }

  .hero-deck {
    width: clamp(180px, 50vw, 280px);
  }

  .hero-left {
    padding: 1.5rem 2rem 5rem;
  }

  .hero-number {
    display: none;
  }

  .scroll-hint {
    display: none;
  }
}

@media (max-width: 580px) {
  .hero-cta {
    flex-direction: column;
  }

  .hero-cta .btn {
    text-align: center;
  }

  .hero-deck {
    width: 55vw;
  }
}
</style>

<script>
  (() => {
    const dataEl = document.getElementById('hero-card-data');
    if (!dataEl) return;

    const cards: Array<{ image: string; title: string }> = JSON.parse(dataEl.textContent || '[]');
    if (cards.length < 1) return;

    const n = cards.length;
    const frontCard = document.getElementById('deck-front') as HTMLElement;
    const frontImg = document.getElementById('deck-front-img') as HTMLImageElement;
    const captionEl = document.getElementById('deck-caption') as HTMLElement;
    const backCards = document.querySelectorAll<HTMLElement>('.deck-card--back');

    let current = 0;
    let busy = false;

    const EXIT_NAME_NEXT = 'heroExitNext';
    const EXIT_NAME_PREV = 'heroExitPrev';
    const EXIT_MS = 500;

    function syncStackImages(index: number) {
      backCards.forEach((el, i) => {
        const depth = i + 1;
        const img = el.querySelector('img');
        if (!img) return;
        const idx = (index + depth) % n;
        if (img.getAttribute('src') !== cards[idx].image) {
          img.src = cards[idx].image;
        }
        img.alt = cards[idx].title;
      });
    }

    function waitAnimEnd(el: HTMLElement, nameSubstr: string, fallbackMs: number): Promise<void> {
      return new Promise((resolve) => {
        let done = false;
        const finish = () => {
          if (done) return;
          done = true;
          el.removeEventListener('animationend', onEnd);
          window.clearTimeout(tid);
          resolve();
        };
        const onEnd = (e: AnimationEvent) => {
          if (e.target !== el) return;
          if (!e.animationName || !e.animationName.includes(nameSubstr)) return;
          finish();
        };
        el.addEventListener('animationend', onEnd);
        const tid = window.setTimeout(finish, fallbackMs);
      });
    }

    function updateCaption() {
      captionEl.textContent = cards[current].title;
    }

    async function animateTo(newIndex: number, direction: 'forward' | 'backward') {
      if (busy || newIndex === current || n <= 1) return;
      busy = true;
      frontCard.classList.add('is-busy');
      frontCard.classList.remove('anim-exit-next', 'anim-exit-prev', 'swap-phase');

      const exitClass = direction === 'forward' ? 'anim-exit-next' : 'anim-exit-prev';
      const exitName = direction === 'forward' ? EXIT_NAME_NEXT : EXIT_NAME_PREV;

      void frontCard.offsetHeight;
      frontCard.classList.add(exitClass);
      await waitAnimEnd(frontCard, exitName, EXIT_MS);

      /* Одним кадром: убрать exit, скрыть карту — без промежуточного «базового» стиля */
      frontCard.classList.remove(exitClass);
      frontCard.classList.add('swap-phase');
      void frontCard.offsetHeight;

      current = newIndex;
      frontImg.src = cards[current].image;
      frontImg.alt = cards[current].title;

      try {
        if ('decode' in frontImg) {
          await frontImg.decode();
        }
      } catch {
        /* decode can reject for broken image; still continue */
      }

      /*
       * Один кадр при opacity:0, затем показ без fade — без «дёрганья» в конце анимации.
       * syncStackImages только после показа лицевой карты, чтобы стопка под ней не
       * перерисовывалась в момент, когда сквозь прозрачный front виден верх задних карт.
       */
      await new Promise<void>((resolve) => {
        requestAnimationFrame(() => {
          requestAnimationFrame(resolve);
        });
      });

      frontCard.classList.remove('swap-phase');
      void frontCard.offsetHeight;

      syncStackImages(current);
      updateCaption();

      frontCard.classList.remove('is-busy');
      busy = false;
    }

    function goNext() {
      void animateTo((current + 1) % n, 'forward');
    }

    function goPrev() {
      void animateTo((current - 1 + n) % n, 'backward');
    }

    document.addEventListener('keydown', (e) => {
      const hero = document.getElementById('hero');
      if (!hero) return;
      const rect = hero.getBoundingClientRect();
      const inView = rect.top < window.innerHeight && rect.bottom > 0;
      if (!inView || busy) return;
      if (e.key === 'ArrowRight') goNext();
      if (e.key === 'ArrowLeft') goPrev();
    });

    let touchStartX = 0;
    let skipDeckClick = false;
    frontCard.addEventListener(
      'touchstart',
      (e) => {
        touchStartX = e.changedTouches[0].clientX;
      },
      { passive: true }
    );
    frontCard.addEventListener(
      'touchend',
      (e) => {
        if (n <= 1) return;
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) < 48) return;
        skipDeckClick = true;
        window.setTimeout(() => {
          skipDeckClick = false;
        }, 320);
        if (dx < 0) goNext();
        else goPrev();
      },
      { passive: true }
    );

    frontCard.addEventListener('click', (e) => {
      e.preventDefault();
      if (n <= 1 || skipDeckClick) return;
      goNext();
    });

    frontCard.addEventListener('keydown', (e) => {
      if (n <= 1) return;
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        goNext();
      }
    });

    syncStackImages(0);
  })();
</script>
