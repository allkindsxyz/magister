---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get all cards to populate the hero deck
const allCards = await getCollection('cards');
const deckCards = [
  ...allCards.filter(c => c.data.featured),
  ...allCards.filter(c => !c.data.featured),
].slice(0, 6);
---

<section class="hero hatch" id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow2"></div>

  <div class="hero-left">
    <div class="hero-number" aria-hidden="true">54</div>
    <p class="hero-eyebrow">{t('hero.eyebrow')}</p>
    <h1 class="hero-title">
      {t('hero.title')}
      <span class="hero-title-sub">{t('hero.subtitle')}</span>
    </h1>
    <p class="hero-body">{t('hero.body')}</p>
    <div class="hero-cta">
      <a href="#acquire" class="btn btn-gold">{t('hero.cta_primary')}</a>
      <a href="#gallery" class="btn btn-outline">{t('hero.cta_secondary')}</a>
    </div>
  </div>

  <div class="hero-right">
    <div class="hero-deck" id="hero-deck">
      <!-- Stack of back cards (visible) -->
      <div class="deck-stack" id="deck-stack">
        {deckCards.slice(1).map((card, i) => (
          <div
            class="deck-card deck-card--back"
            data-index={i + 1}
            style={`
              --stack-offset: ${(i + 1) * 10}px;
              --stack-rotate: ${(i + 1) * -3 + 2}deg;
              --stack-z: ${deckCards.length - i - 1};
              --stack-brightness: ${1 - (i + 1) * 0.12};
            `}
          >
            <img src={card.data.image} alt={card.data.title[lang]} />
          </div>
        ))}
      </div>

      <!-- Active front card -->
      <div class="deck-card deck-card--front" id="deck-front">
        <img
          id="deck-front-img"
          src={deckCards[0]?.data.image}
          alt={deckCards[0]?.data.title[lang]}
        />
      </div>

      <div class="hero-card-shadow"></div>
    </div>

    <!-- Card navigation -->
    <div class="deck-nav">
      <button class="deck-btn deck-btn--prev" id="deck-prev" aria-label="Previous card">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="deck-dots" id="deck-dots">
        {deckCards.map((_, i) => (
          <button
            class={`deck-dot ${i === 0 ? 'active' : ''}`}
            data-dot={i}
            aria-label={`Card ${i + 1}`}
          ></button>
        ))}
      </div>

      <button class="deck-btn deck-btn--next" id="deck-next" aria-label="Next card">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- Current card title -->
    <p class="deck-caption" id="deck-caption">{deckCards[0]?.data.title[lang]}</p>
  </div>

  <div class="scroll-hint">
    <span>{t('scroll_hint')}</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- Card data for JS -->
<script
  id="hero-card-data"
  type="application/json"
  set:html={JSON.stringify(
    deckCards.map(c => ({
      image: c.data.image,
      title: c.data.title[lang],
    }))
  )}
></script>

<style>
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding-top: 5rem;
}

.hero-glow {
  position: absolute;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200,151,58,.07) 0%, transparent 70%);
  right: -50px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
}

.hero-glow2 {
  position: absolute;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(122,30,0,.1) 0%, transparent 70%);
  left: 0;
  top: 15%;
  pointer-events: none;
}

/* ── LEFT COLUMN ──────────────────────────── */
.hero-left {
  padding: 10rem 4rem 6rem 6rem;
  position: relative;
  z-index: 2;
}

.hero-number {
  font-family: 'Cinzel Decorative', serif;
  font-size: 11rem;
  font-weight: 700;
  color: rgba(200,151,58,.05);
  position: absolute;
  top: 4rem;
  left: 2rem;
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

.hero-eyebrow {
  font-family: 'Cinzel', serif;
  font-size: .62rem;
  letter-spacing: .55em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 2rem;
  opacity: 0;
  animation: fadeLeft 1s ease .2s forwards;
}

.hero-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(3.5rem, 6vw, 6.5rem);
  font-weight: 700;
  line-height: .95;
  color: var(--parch);
  text-shadow: 0 2px 40px rgba(200,151,58,.12);
  margin-bottom: 2rem;
  opacity: 0;
  animation: fadeLeft 1.1s ease .35s forwards;
  /* Stay within left column — no overflow */
  max-width: 100%;
}

.hero-title-sub {
  display: block;
  font-size: clamp(1.6rem, 3vw, 2.8rem);
  color: var(--gold);
  letter-spacing: .35em;
  margin-top: .5rem;
}

.hero-body {
  font-size: 1rem;
  color: var(--warm);
  font-style: italic;
  max-width: 400px;
  margin-bottom: 3rem;
  opacity: 0;
  animation: fadeLeft 1.1s ease .5s forwards;
  line-height: 1.75;
}

.hero-cta {
  display: flex;
  gap: 1.2rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeLeft 1s ease .65s forwards;
}

/* ── RIGHT COLUMN ─────────────────────────── */
.hero-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rem 5rem 6rem 2rem;
  position: relative;
  z-index: 3;
  opacity: 0;
  animation: fadeLeft 1.3s ease .5s forwards;
}

/* ── DECK ─────────────────────────────────── */
.hero-deck {
  position: relative;
  width: clamp(240px, 28vw, 360px);
  cursor: pointer;
}

.hero-card-shadow {
  position: absolute;
  width: 80%;
  height: 24px;
  background: rgba(0,0,0,.5);
  bottom: -28px;
  left: 10%;
  filter: blur(20px);
  border-radius: 50%;
  pointer-events: none;
}

/* Back cards in the stack */
.deck-card--back {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  border-radius: 8px;
  overflow: hidden;
  transform:
    translateX(var(--stack-offset))
    rotate(var(--stack-rotate));
  z-index: var(--stack-z);
  box-shadow:
    0 20px 60px rgba(0,0,0,.6),
    0 0 0 1px rgba(200,151,58,.18);
  filter: brightness(var(--stack-brightness));
  transition: transform .5s cubic-bezier(.23,1,.32,1), filter .5s;
  pointer-events: none;
}

.deck-card--back img {
  width: 100%;
  display: block;
  filter: sepia(12%) contrast(1.05);
}

/* Front (active) card */
.deck-card--front {
  position: relative;
  z-index: 10;
  border-radius: 8px;
  overflow: hidden;
  box-shadow:
    0 40px 100px rgba(0,0,0,.8),
    0 0 0 1px rgba(200,151,58,.4),
    inset 0 0 0 1px rgba(255,255,255,.05);
  transform: rotate(-1deg);
  transition: transform .5s cubic-bezier(.23,1,.32,1), box-shadow .5s;
  animation: cardFloat 6s ease-in-out 1.8s infinite;
}

.deck-card--front:hover {
  transform: rotate(0deg) scale(1.02);
  box-shadow:
    0 50px 120px rgba(0,0,0,.85),
    0 0 0 1px rgba(200,151,58,.6),
    inset 0 0 0 1px rgba(255,255,255,.08);
}

.deck-card--front img {
  width: 100%;
  display: block;
  filter: contrast(1.06) sepia(8%);
}

/* Card flip animation */
.deck-card--front.is-flipping {
  animation: cardFlip .5s ease forwards !important;
}

@keyframes cardFloat {
  0%, 100% { transform: rotate(-1deg) translateY(0); }
  50%       { transform: rotate(-1deg) translateY(-12px); }
}

@keyframes cardFlip {
  0%   { transform: rotate(-1deg) translateY(0) scale(1); }
  40%  { transform: rotate(-1deg) translateY(-20px) scale(0.96) rotateY(90deg); }
  60%  { transform: rotate(-1deg) translateY(-20px) scale(0.96) rotateY(-90deg); }
  100% { transform: rotate(-1deg) translateY(0) scale(1); }
}

/* ── NAV & DOTS ────────────────────────────── */
.deck-nav {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  margin-top: 2.2rem;
}

.deck-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid rgba(200,151,58,.25);
  background: rgba(200,151,58,.05);
  color: var(--dim);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: border-color .25s, background .25s, color .25s, transform .2s;
  flex-shrink: 0;
}

.deck-btn:hover {
  border-color: var(--gold);
  background: rgba(200,151,58,.12);
  color: var(--gold);
  transform: scale(1.08);
}

.deck-dots {
  display: flex;
  gap: .6rem;
  align-items: center;
}

.deck-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  border: 1px solid rgba(200,151,58,.35);
  background: transparent;
  cursor: pointer;
  transition: background .3s, border-color .3s, transform .3s;
  padding: 0;
}

.deck-dot.active {
  background: var(--gold);
  border-color: var(--gold);
  transform: scale(1.3);
}

.deck-caption {
  font-family: 'Cinzel', serif;
  font-size: .6rem;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: var(--dimmer);
  margin-top: 1rem;
  text-align: center;
  min-height: 1.2em;
  transition: opacity .3s;
}

/* ── SCROLL HINT ───────────────────────────── */
.scroll-hint {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  font-family: 'Cinzel', serif;
  font-size: .55rem;
  letter-spacing: .4em;
  text-transform: uppercase;
  color: var(--dimmer);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .7rem;
  opacity: 0;
  animation: fadeLeft 1s ease 1.6s forwards;
  /* Don't overlap CTA buttons */
  pointer-events: none;
}

.scroll-line {
  width: 1px;
  height: 45px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

/* ── RESPONSIVE ────────────────────────────── */
@media (max-width: 960px) {
  .hero {
    grid-template-columns: 1fr;
    min-height: auto;
    padding-top: 5rem;
  }

  .hero-right {
    padding: 3rem 2rem 1rem;
    order: -1;
  }

  .hero-deck {
    width: clamp(180px, 50vw, 280px);
  }

  .hero-left {
    padding: 1.5rem 2rem 5rem;
  }

  .hero-number {
    display: none;
  }

  .scroll-hint {
    display: none;
  }
}

@media (max-width: 580px) {
  .hero-cta {
    flex-direction: column;
  }

  .hero-cta .btn {
    text-align: center;
  }

  .hero-deck {
    width: 55vw;
  }
}
</style>

<script>
  (() => {
    const dataEl = document.getElementById('hero-card-data');
    if (!dataEl) return;

    const cards: Array<{ image: string; title: string }> = JSON.parse(dataEl.textContent || '[]');
    if (cards.length < 2) return;

    const frontCard = document.getElementById('deck-front') as HTMLElement;
    const frontImg = document.getElementById('deck-front-img') as HTMLImageElement;
    const captionEl = document.getElementById('deck-caption') as HTMLElement;
    const dots = document.querySelectorAll<HTMLButtonElement>('.deck-dot');
    const backCards = document.querySelectorAll<HTMLElement>('.deck-card--back');
    const prevBtn = document.getElementById('deck-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('deck-next') as HTMLButtonElement;

    let current = 0;
    let isAnimating = false;

    function updateBackCards(newIndex: number) {
      // Rearrange back cards so they reflect the new deck order
      backCards.forEach((card, i) => {
        const dataIndex = parseInt(card.dataset.index || '1', 10);
        const relativePos = ((dataIndex - newIndex - 1) + cards.length) % cards.length;
        const visible = relativePos < backCards.length;
        card.style.opacity = visible ? '1' : '0';
        card.style.setProperty('--stack-offset', `${(relativePos + 1) * 10}px`);
        card.style.setProperty('--stack-rotate', `${(relativePos + 1) * -3 + 2}deg`);
        card.style.setProperty('--stack-z', String(backCards.length - relativePos));
        card.style.setProperty('--stack-brightness', String(1 - (relativePos + 1) * 0.12));
      });
    }

    function goTo(index: number) {
      if (isAnimating || index === current) return;
      isAnimating = true;

      const newIndex = (index + cards.length) % cards.length;

      // Flip animation on front card
      frontCard.classList.add('is-flipping');

      setTimeout(() => {
        frontImg.src = cards[newIndex].image;
        frontImg.alt = cards[newIndex].title;
      }, 200); // swap at mid-flip

      setTimeout(() => {
        frontCard.classList.remove('is-flipping');
        captionEl.style.opacity = '0';
        setTimeout(() => {
          captionEl.textContent = cards[newIndex].title;
          captionEl.style.opacity = '1';
        }, 150);
        current = newIndex;
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        updateBackCards(current);
        isAnimating = false;
      }, 500);
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });

    // Keyboard support when hero is focused
    document.addEventListener('keydown', (e) => {
      const hero = document.getElementById('hero');
      if (!hero) return;
      const rect = hero.getBoundingClientRect();
      const inView = rect.top < window.innerHeight && rect.bottom > 0;
      if (!inView) return;
      if (e.key === 'ArrowRight') goTo(current + 1);
      if (e.key === 'ArrowLeft') goTo(current - 1);
    });

    // Swipe support
    let touchStartX = 0;
    const deck = document.getElementById('hero-deck');
    deck?.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    deck?.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
    }, { passive: true });

    // Initialize back card positions
    updateBackCards(0);
  })();
</script>
