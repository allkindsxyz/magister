---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="quote-strip parch-noise">
  <div class="quote-inner reveal">
    <span class="quote-mark" aria-hidden="true">"</span>
    <p class="quote-text">{t('quote.text')}</p>
    <span class="quote-attr">{t('quote.attribution')}</span>
  </div>
</div>

<style>
.quote-strip {
  background: var(--parch);
  padding: 5rem 6rem;
  position: relative;
  overflow: hidden;
}

.quote-strip::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 15% 50%, rgba(122,30,0,.07) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 30%, rgba(122,30,0,.05) 0%, transparent 45%),
    radial-gradient(ellipse at 50% 80%, rgba(122,30,0,.04) 0%, transparent 40%);
}

.quote-inner {
  max-width: 900px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
  text-align: center;
}

.quote-mark {
  font-family: 'Cinzel Decorative', serif;
  font-size: 6rem;
  line-height: .6;
  color: rgba(122,30,0,.18);
  display: block;
  margin-bottom: .5rem;
}

.quote-text {
  font-family: 'IM Fell English', serif;
  font-style: italic;
  font-size: clamp(1.3rem, 2.5vw, 1.9rem);
  color: var(--ink);
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.quote-attr {
  font-family: 'Cinzel', serif;
  font-size: .62rem;
  letter-spacing: .4em;
  text-transform: uppercase;
  color: rgba(122,30,0,.5);
}

@media (max-width: 960px) {
  .quote-strip {
    padding: 4rem 2.5rem;
  }
}
</style>
