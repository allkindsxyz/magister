---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const games = await getCollection('games');
const sorted = games.sort((a, b) => a.data.number.localeCompare(b.data.number));
---

<section class="games hatch" id="games">
  <div class="games-header reveal">
    <p class="section-label">{t('games.label')}</p>
    <h2 class="games-title">{t('games.title')}</h2>
  </div>

  <div class="games-panels">
    {sorted.map((game, i) => (
      <div class="game-panel reveal" style={`transition-delay: ${i * 0.1}s`}>
        <span class="game-bg-num" aria-hidden="true">{game.data.number}</span>
        <p class="game-num">{t('games.label').split(' ')[0]} {game.data.number}</p>
        <h3 class="game-name">{game.data.title[lang]}</h3>
        <p class="game-desc">{game.data.description[lang]}</p>
        <div class="game-meta">
          <span>
            <span class="game-meta-label">{t('games.players_label')}:</span>
            <span class="game-meta-val">{game.data.players}</span>
          </span>
          <span class="game-meta-sep">·</span>
          <span>
            <span class="game-meta-label">{t('games.duration_label')}:</span>
            <span class="game-meta-val">{game.data.duration[lang]}</span>
          </span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
.games {
  padding: var(--section-pad-v) 0;
  background: var(--dark);
  position: relative;
  overflow: hidden;
}

.games-header {
  text-align: center;
  margin-bottom: 6rem;
  padding: 0 3rem;
}

.games-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  color: var(--parch);
}

.games-panels {
  display: grid;
  grid-template-columns: 1fr 1fr;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 3rem;
  gap: 2px;
}

.game-panel {
  padding: 3.5rem;
  border: 1px solid rgba(200,151,58,.08);
  position: relative;
  overflow: hidden;
  transition: background .4s, border-color .4s;
}

.game-panel:hover {
  background: rgba(200,151,58,.04);
  border-color: rgba(200,151,58,.2);
}

.game-bg-num {
  position: absolute;
  bottom: -1rem;
  right: 1rem;
  font-family: 'Cinzel Decorative', serif;
  font-size: 8rem;
  font-weight: 700;
  color: rgba(200,151,58,.05);
  line-height: 1;
  pointer-events: none;
  transition: color .4s;
}

.game-panel:hover .game-bg-num {
  color: rgba(200,151,58,.09);
}

.game-num {
  font-family: 'Cinzel', serif;
  font-size: .6rem;
  letter-spacing: .4em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.2rem;
}

.game-name {
  font-family: 'Cinzel Decorative', serif;
  font-size: 1.4rem;
  color: var(--parch);
  margin-bottom: 1rem;
  line-height: 1.25;
}

.game-desc {
  font-size: .95rem;
  font-style: italic;
  color: var(--dim);
  line-height: 1.8;
  margin-bottom: 1.5rem;
}

.game-meta {
  font-family: 'Cinzel', serif;
  font-size: .58rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--dimmer);
  display: flex;
  gap: .8rem;
  align-items: center;
  flex-wrap: wrap;
}

.game-meta-label {
  color: var(--dimmer);
}

.game-meta-val {
  color: var(--gold);
}

.game-meta-sep {
  color: rgba(200,151,58,.3);
}

@media (max-width: 960px) {
  .games-panels {
    grid-template-columns: 1fr;
    padding: 0 2rem;
  }

  .games-header {
    margin-bottom: 3rem;
  }
}
</style>
