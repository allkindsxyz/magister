---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const t = useTranslations(Astro.props.lang);

const drKleinArthiveHref =
  'https://arthive.com/ru/artists/90797~Vasilij_Vasil%27evich_Pochitskij_dr_Klein';
---

<section class="artist" id="artist">
  <div class="artist-parch parch-noise reveal-left">
    <div class="artist-parch-inner">
      <p class="section-label artist-kicker artist-kicker--light">{t('artist.eyebrow')}</p>
      <h2 class="artist-block-title artist-block-title--ink">{t('artist.title')}</h2>
      <p class="artist-lead">{t('artist.lead')}</p>

      <div class="artist-pair">
        <div class="artist-person">
          <h3 class="artist-person-name">{t('artist.magister_heading')}</h3>
          <p class="artist-person-bio">{t('artist.magister_bio')}</p>
        </div>
        <div class="artist-person">
          <h3 class="artist-person-name">{t('artist.drklein_heading')}</h3>
          <p class="artist-person-bio">{t('artist.drklein_bio')}</p>
          <a
            class="artist-ext-link"
            href={drKleinArthiveHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('artist.drklein_link')}
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="artist-dark reveal-right">
    <p class="section-label artist-kicker artist-kicker--dark">{t('artist.process_label')}</p>
    <h3 class="artist-block-title artist-block-title--parch">{t('artist.process_title')}</h3>
    <p class="artist-process-intro">{t('artist.process_intro')}</p>
    <div class="artist-process-copy">
      <p class="artist-dark-body">{t('artist.process_body_1')}</p>
      <p class="artist-dark-body">{t('artist.process_body_2')}</p>
      <p class="artist-dark-body">{t('artist.process_body_3')}</p>
    </div>
  </div>
</section>

<style>
.artist {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: start;
  position: relative;
}

.artist-parch {
  background-color: var(--parch);
  background-image:
    radial-gradient(ellipse at 20% 70%, rgba(122, 30, 0, 0.09) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(122, 30, 0, 0.06) 0%, transparent 45%),
    radial-gradient(ellipse at 50% 50%, rgba(122, 30, 0, 0.04) 0%, transparent 60%);
  padding: 5rem 4rem 5.5rem;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  position: relative;
  overflow: hidden;
}

.artist-parch-inner {
  position: relative;
  z-index: 1;
  max-width: 32rem;
}

.artist-kicker.section-label {
  margin-bottom: 0.5rem;
}

.artist-kicker--light {
  color: rgba(122, 30, 0, 0.55);
}

.artist-kicker--dark {
  color: rgba(200, 151, 58, 0.75);
}

.artist-block-title {
  font-family: 'Cinzel Decorative', serif;
  font-size: clamp(1.65rem, 2.8vw, 2.35rem);
  line-height: 1.15;
  margin: 0 0 1rem;
}

.artist-block-title--ink {
  color: var(--ink);
}

.artist-block-title--parch {
  color: var(--parch);
}

.artist-lead {
  font-size: 0.95rem;
  color: rgba(12, 7, 1, 0.72);
  line-height: 1.65;
  margin: 0 0 1.75rem;
}

.artist-pair {
  display: flex;
  flex-direction: column;
  gap: 1.35rem;
}

.artist-person {
  padding-top: 1.25rem;
  border-top: 1px solid rgba(122, 30, 0, 0.18);
}

.artist-person:first-of-type {
  padding-top: 0;
  border-top: none;
}

.artist-person-name {
  font-family: 'Cinzel', serif;
  font-size: 0.68rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink);
  margin: 0 0 0.55rem;
  line-height: 1.35;
}

.artist-person-bio {
  font-size: 0.9rem;
  font-style: italic;
  color: rgba(12, 7, 1, 0.68);
  line-height: 1.65;
  margin: 0;
}

.artist-ext-link {
  display: inline-block;
  margin-top: 0.65rem;
  font-family: 'Cinzel', serif;
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(122, 30, 0, 0.85);
  text-decoration: none;
  border-bottom: 1px solid rgba(122, 30, 0, 0.35);
  transition: color 0.2s, border-color 0.2s;
}

.artist-ext-link:hover {
  color: var(--rust);
  border-bottom-color: var(--rust);
}

.artist-dark {
  background: var(--dark3);
  padding: 5rem 4rem 5.5rem;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.artist-process-intro {
  font-family: 'Cinzel', serif;
  font-size: 0.72rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gold);
  line-height: 1.55;
  margin: 0 0 1.35rem;
  max-width: 32rem;
}

.artist-process-copy {
  max-width: 32rem;
  padding-left: 0.85rem;
  border-left: 2px solid rgba(200, 151, 58, 0.35);
}

.artist-dark-body {
  color: var(--dim);
  font-style: italic;
  font-size: 0.92rem;
  line-height: 1.78;
  margin: 0;
}

.artist-dark-body + .artist-dark-body {
  margin-top: 1.05rem;
}

@media (max-width: 960px) {
  .artist {
    grid-template-columns: 1fr;
  }

  .artist-parch {
    padding: 4rem 2.25rem;
  }

  .artist-parch-inner {
    max-width: none;
  }

  .artist-dark {
    padding: 4rem 2.25rem;
  }
}
</style>
